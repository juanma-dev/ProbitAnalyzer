<Window x:Class="ProbitAnalyzer.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca de Probit Analyzer"
        Width="480" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0F1117"
        Foreground="#E2E8F0"
        FontFamily="Segoe UI, Arial"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border CornerRadius="16" BorderThickness="1" ClipToBounds="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#6366F1" Offset="0"/>
                <GradientStop Color="#A855F7" Offset="0.5"/>
                <GradientStop Color="#EC4899" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0F1117" Offset="0"/>
                <GradientStop Color="#151830" Offset="0.5"/>
                <GradientStop Color="#0F1117" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Close Button -->
            <Button Grid.Row="0" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,12,16,0" Click="Close_Click" Cursor="Hand"
                    FontSize="14" Foreground="#64748B" Background="Transparent" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="4" Padding="8,4" Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2D1418"/>
                                <Setter Property="Foreground" Value="#F87171"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Content -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40,20">

                <!-- App Icon -->
                <TextBlock Text="🧪" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <!-- App Name with Gradient -->
                <TextBlock FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#63B3ED" Offset="0"/>
                            <GradientStop Color="#A855F7" Offset="0.5"/>
                            <GradientStop Color="#EC4899" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                    Probit Analyzer
                </TextBlock>

                <!-- Version -->
                <TextBlock Text="Versión 1.0.0" FontSize="13" Foreground="#94A3B8" 
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Separator -->
                <Border Height="1" Margin="0,0,0,20" CornerRadius="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#2D3154" Offset="0.3"/>
                            <GradientStop Color="#2D3154" Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Author -->
                <TextBlock FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,6">
                    <Run Text="Hecho por " Foreground="#94A3B8"/>
                    <Run Text="Juanma" FontWeight="Bold" Foreground="#63B3ED"/>
                </TextBlock>

                <!-- Copyright -->
                <TextBlock Text="Copyright © 2026 Juanma" FontSize="12" 
                           Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Separator -->
                <Border Height="1" Margin="0,0,0,20" CornerRadius="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#2D3154" Offset="0.3"/>
                            <GradientStop Color="#2D3154" Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- License -->
                <Border CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                    <Border.Background>
                        <SolidColorBrush Color="#1A1D2E"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#2D3154"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <TextBlock Text="📜 Licencia" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#A855F7" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#94A3B8" LineHeight="18">
                            Este programa es software libre: usted puede redistribuirlo y/o modificarlo
                            bajo los términos de la GNU General Public License publicada por la
                            Free Software Foundation, versión 3 de la Licencia, o cualquier versión posterior.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- GitHub Link -->
                <TextBlock HorizontalAlignment="Center" Margin="0,4,0,16" FontSize="13">
                    <Hyperlink NavigateUri="https://github.com/juanma-dev/ProbitAnalyzer"
                               RequestNavigate="Hyperlink_RequestNavigate" Foreground="#63B3ED">
                        github.com/juanma-dev/ProbitAnalyzer
                    </Hyperlink>
                </TextBlock>

            </StackPanel>

            <!-- Footer -->
            <TextBlock Grid.Row="2" Text="GNU General Public License v3.0" 
                       FontSize="10" Foreground="#475569" HorizontalAlignment="Center" 
                       Margin="0,0,0,16"/>
        </Grid>
    </Border>
</Window>
